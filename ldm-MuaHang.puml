@startuml ldm-MuaHang
!pragma layout smetana
left to right direction

'------------------------------------------------------------------------------
' Chứng từ mua hàng
'------------------------------------------------------------------------------
entity ChungTuMuaHang
{
    *Id: uuid <<PK>> - ID bản ghi

    ' Thuộc tính nghiệp vụ chung
    LoaiNghiepVu: enum! - Loại nghiệp vụ (Mua hàng nhập kho, Mua hàng không qua kho)
    HinhThuc: enum! - Hình thức (Trong nước, Nhập khẩu)
    NhieuHoaDon: boolean - Có nhiều hóa đơn (true/false)

    ' Thông tin chứng từ null nếu có phiếu nhập kho
    SoChungTu: string - Số chứng từ
    NgayChungTu: date - Ngày chứng từ
    NgayHachToan: date - Ngày hạch toán
    MoTa: string - Diễn giải

    ' Thông tin loại tiền và tỷ giá
    LoaiTienId: uuid! <<FK>> - ID loại tiền tệ (reference đến ENT_LoaiTien)
    TyGia: numeric! - Tỷ giá

    ' Thông tin chiết khấu
    LoaiChietKhau: enum! - Loại chiết khấu (Theo tiền, Theo phần trăm, Không chiết khấu)
    GiaTriChietKhau: numeric - Giá trị chiết khấu (áp dụng nếu có chiết khấu) có thể là phần trăm hoặc tiền tùy theo loại chiết khấu

    ' Thông tin nhà cung cấp null nếu có phiếu nhập kho
    NhaCungCapId: uuid! <<FK>> - ID nhà cung cấp
    TenNhaCungCap: string! - Tên nhà cung cấp
    DiaChi: string - Địa chỉ nhà cung cấp

    ' Thông tin điều khoản thanh toán và nợ null nếu thanh toán ngay
    DieuKhoanThanhToanId: uuid <<FK>> - ID điều khoản thanh toán (reference đến ENT_DieuKhoanThanhToan)
    SoNgayDuocNo: int - Số ngày được nợ
    HanThanhToan: date - Hạn thanh toán

    ' Thông tin mua hàng
    NhanVienMuaHangId: uuid <<FK>> - ID nhân viên mua hàng

    ' Thông tin thanh toán
    ThanhToanNgay: boolean - Thanh toán ngay (true/false)
    HinhThucThanhToan: enum! - Hình thức thanh toán (Tiền mặt, Ủy nhiệm chi, Séc tiền mặt, Séc chuyển khoản)

    ' Nhóm thông tin tổng hợp theo chứng từ
    TongTienHangHoa: numeric - Tổng tiền hàng hóa trước khi chiết khấu
    TongTienChietKhau: numeric - Tổng tiền chiết khấu
    TongTienTruocThue: numeric - Tổng tiền trước thuế
    TongTienThueGTGT: numeric - Tổng tiền thuế GTGT
    TongTienSauThue: numeric - Tổng tiền sau thuế
    ChiPhi: numeric - Chi phí mua hàng
    TongTienThanhToan: numeric - Tổng tiền thanh toán

    ' Nhóm thông tin quy đổi
    TongTienHangHoaQuyDoi: numeric - Tổng tiền hàng hóa trước khi chiết khấu
    TongTienChietKhauQuyDoi: numeric - Tổng tiền chiết khấu
    TongTienTruocThueQuyDoi: numeric - Tổng tiền trước thuế
    TongTienThueGTGTQuyDoi: numeric - Tổng tiền thuế GTGT
    TongTienSauThueQuyDoi: numeric - Tổng tiền sau thuế
    ChiPhiQuyDoi: numeric - Chi phí mua hàng
    TongTienThanhToanQuyDoi: numeric - Tổng tiền thanh toán

    ' Nhóm thông tin thanh toán
    SoTienDaThanhToan: numeric - Số tiền đã thanh toán
    SoTienDaThanhToanQuyDoi: numeric - Số tiền đã thanh toán quy đổi

    ' Nhóm thông tin trạng thái
    TrangThaiChungTu: enum! - Trạng thái chứng từ (Chưa ghi sổ, Đã ghi sổ)
    TrangThaiHoaDon: enum! - Trạng thái hóa đơn (Đã có hóa đơn / Chưa có hóa đơn / Không có hóa đơn)
    TrangThaiNhanHoaDon: enum! - Trạng thái nhận hóa đơn (Đã có hóa đơn / Chưa có hóa đơn / Không có hóa đơn)
    TrangThaiThanhToan: enum! - Trạng thái thanh toán (Đã thanh toán / Chưa thanh toán / Đã thanh toán một phần)

    ' Thông tin giảm trừ do trả lại hoặc điều chỉnh giá
    TongTienGiamTru: numeric - Tổng tiền giảm trừ
    TongTienGiamTruQuyDoi: numeric - Tổng tiền giảm trừ quy đổi
}

