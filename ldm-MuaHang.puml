entity ChungTuTraLaiHangMua
{
    *Id: uuid <<PK>> - ID bản ghi

    ' Thuộc tính nghiệp vụ chung
    PhuongThucLapHoaDon: enum! - Hình thức (Người bán xuất hóa đơn điều chỉnh/Người mua xuất hóa đơn/Không có hóa đơn)
    ThuTienNgay: boolean! - Giảm trừ công nợ/Thu tiền ngay
    HinhThucThanhToan: enum - Tiền mặt/Chuyển khoản (chỉ có giá trị nếu ThuTienNgay = True)
    TraLaiHangTrongKho: boolean! - Trả lại hàng trong kho (true/false)

    ' Thông tin chứng từ null nếu có phiếu xuất kho
    SoChungTu: string - Số chứng từ
    NgayChungTu: date - Ngày chứng từ
    NgayHachToan: date - Ngày hạch toán
    MoTa: string - Diễn giải

    ' Thông tin loại tiền và tỷ giá
    LoaiTienId: uuid! <<FK>> - ID loại tiền tệ (reference đến ENT_LoaiTien)
    TyGia: numeric! - Tỷ giá

    ' Thông tin nhà cung cấp null nếu có phiếu xuất kho
    NhaCungCapId: uuid! <<FK>> - ID nhà cung cấp
    TenNhaCungCap: string! - Tên nhà cung cấp
    DiaChi: string - Địa chỉ nhà cung cấp
    MaSoThue: string - Mã số thuế

    ' Thông tin nhân viên
    NhanVienId: uuid <<FK>> - ID nhân viên mua hàng

    ' Nhóm thông tin tổng hợp theo chứng từ
    TongTienHangHoa: numeric - Tổng tiền hàng hóa trả lại
    TongTienThueGTGT: numeric - Tổng tiền thuế GTGT giảm đi
    TongTienThanhToan: numeric - Tổng tiền thanh toán/điều chỉnh

    ' Nhóm thông tin quy đổi
    TongTienHangHoaQuyDoi: numeric - Tổng tiền hàng hóa trả lại quy đổi ra đồng tiền hạch toán
    TongTienThueGTGTQuyDoi: numeric - Tổng tiền thuế GTGT giảm đi quy đổi ra đồng tiền hạch toán
    TongTienThanhToanQuyDoi: numeric - Tổng tiền thanh toán/điều chỉnh quy đổi ra đồng tiền hạch toán

    ' Nhóm thông tin thanh toán
    SoTienDaThanhToan: numeric - Số tiền đã thanh toán
    SoTienDaThanhToanQuyDoi: numeric - Số tiền đã thanh toán quy đổi

    ' Nhóm thông tin trạng thái
    TrangThaiChungTu: enum! - Trạng thái chứng từ (Chưa ghi sổ, Đã ghi sổ)
    TrangThaiThanhToan: enum! - Trạng thái thanh toán (Đã thanh toán / Chưa thanh toán / Đã thanh toán một phần)
}

